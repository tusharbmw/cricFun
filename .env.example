# ============================================================
# CricFun Environment Variables
# Copy this file to .env and fill in your values
# DO NOT use `export` - python-dotenv loads these directly
# ============================================================

# Django Core
DEBUG=True
SECRET_KEY=your-secret-key-here

# Allowed Hosts (comma-separated for production)
# ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Oracle Database
DB_DJ_USER=your_db_user
DB_DJ_PWD=your_db_password
DB_NAME=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=your-host)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=your-service)))

# Redis (local: redis://127.0.0.1:6379/0 | Docker: redis://redis:6379/0)
REDIS_URL=redis://127.0.0.1:6379/0

# Cricket API (https://cricapi.com)
CRIC_API_KEY=your_cricapi_key
# CRIC_TOURNAMENT_ID is now managed via Admin → Core → Site Settings

# Google OAuth (via django-allauth)
GOOGLE_API_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Web Push (VAPID) — generate with: python manage.py generate_vapid_keys
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_ADMIN_EMAIL=your@email.com
